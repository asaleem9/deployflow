{
  "name": "@deployflow/motion",
  "version": "0.1.0",
  "private": true,
  "description": "GSAP-based motion engine and shared animation primitives for DeployFlow",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "check:lint": "oxlint --max-warnings=10 .",
    "check:types": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@gsap/react": "catalog:",
    "gsap": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "@plane/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react-router": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-router": "*"
  }
}
