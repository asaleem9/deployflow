#
# Fires the keep-alive load twice a day. Paired with keepalive.service.

[Unit]
Description=Run the DeployFlow keep-alive load twice daily

[Timer]
OnCalendar=*-*-* 06:00:00
OnCalendar=*-*-* 18:00:00
Persistent=true

[Install]
WantedBy=timers.target
